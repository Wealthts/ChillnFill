              "raw": "{\n  \"table_number\": \"{{tableNumber}}\",\n  \"session_id\": \"{{sessionId}}\",\n  \"notes\": \"Postman test order\",\n  \"items\": [\n    {\n      \"menu_id\": 1,\n      \"quantity\": 1,\n      \"notes\": \"Spiciness: Medium\"\n    }\n  ]\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "let data = {};",
                  "try { data = pm.response.json(); } catch (e) {}",
                  "if (data && data.order_id) pm.collectionVariables.set(\"orderId\", String(data.order_id));",
                  "if (Array.isArray(data.order_ids) && data.order_ids.length) {",
                  "  pm.collectionVariables.set(\"orderId\", String(data.order_ids[0]));",
                  "  pm.collectionVariables.set(\"orderIdsJson\", JSON.stringify(data.order_ids));",
                  "}"
